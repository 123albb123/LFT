<Window x:Class="LanFileTransfer.App.QrWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="二维码" Width="390" Height="470" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" Background="#F3F7F4">
    <Grid Margin="24">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <TextBlock x:Name="HeadingText" Text="扫码打开" FontSize="21" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,4,0,14"/>
        <Border Grid.Row="1" Background="White" BorderBrush="#DCE6DF" BorderThickness="1" CornerRadius="16" Padding="18"><Image x:Name="QrImage" Stretch="Uniform"/></Border>
        <TextBox x:Name="AddressTextBox" Grid.Row="2" Margin="0,14,0,10" Padding="9" IsReadOnly="True" TextAlignment="Center" BorderBrush="#DCE6DF"/>
        <Button Grid.Row="3" Content="复制地址" Height="38" Background="#147A4A" Foreground="White" BorderThickness="0" Click="CopyButton_Click"/>
    </Grid>
</Window>
