<Window x:Class="LanFileTransfer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" Title="内网文件传输工具"
        Width="1120" Height="720" MinWidth="820" MinHeight="620"
        WindowStartupLocation="CenterScreen" Background="#F3F7F4"
        FontFamily="Microsoft YaHei UI" UseLayoutRounding="True" SnapsToDevicePixels="True" TextOptions.TextFormattingMode="Display"
        AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver"
        Closing="Window_Closing" Loaded="Window_Loaded" SizeChanged="Window_SizeChanged">
    <Window.Resources>
        <SolidColorBrush x:Key="Green" Color="#147A4A"/>
        <SolidColorBrush x:Key="GreenDark" Color="#0C5E37"/>
        <SolidColorBrush x:Key="GreenSoft" Color="#E4F3E9"/>
        <SolidColorBrush x:Key="GreenSelection" Color="#D8EFE1"/>
        <SolidColorBrush x:Key="Ink" Color="#17231C"/>
        <SolidColorBrush x:Key="Muted" Color="#647169"/>
        <SolidColorBrush x:Key="Line" Color="#DCE6DF"/>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="13,7"/>
            <Setter Property="Margin" Value="0,0,7,0"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="#E7EFE9"/>
            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True"><Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource Green}"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.86"/></Trigger>
                <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.45"/></Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource Green}"/><Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#FCE9E9"/><Setter Property="Foreground" Value="#A92F2F"/>
        </Style>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/><Setter Property="BorderBrush" Value="{StaticResource Line}"/>
            <Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="13"/>
            <Setter Property="Padding" Value="15"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="9,6"/><Setter Property="BorderBrush" Value="{StaticResource Line}"/>
            <Setter Property="BorderThickness" Value="1"/><Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="White"/><Setter Property="Foreground" Value="{StaticResource Ink}"/>
            <Setter Property="CaretBrush" Value="{StaticResource Green}"/><Setter Property="SelectionBrush" Value="{StaticResource Green}"/>
            <Style.Triggers><Trigger Property="IsKeyboardFocusWithin" Value="True"><Setter Property="BorderBrush" Value="{StaticResource Green}"/></Trigger></Style.Triggers>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="10,0"/><Setter Property="BorderBrush" Value="{StaticResource Line}"/>
            <Setter Property="BorderThickness" Value="1"/><Setter Property="MinHeight" Value="34"/>
            <Setter Property="Background" Value="White"/><Setter Property="Foreground" Value="{StaticResource Ink}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/><Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value><Style TargetType="ComboBoxItem"><Setter Property="Padding" Value="10,7"/><Setter Property="MinHeight" Value="32"/><Setter Property="VerticalContentAlignment" Value="Center"/><Setter Property="Foreground" Value="{StaticResource Ink}"/><Setter Property="Background" Value="White"/><Style.Triggers><Trigger Property="IsHighlighted" Value="True"><Setter Property="Background" Value="{StaticResource GreenSoft}"/><Setter Property="Foreground" Value="{StaticResource GreenDark}"/></Trigger><Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="{StaticResource GreenSelection}"/><Setter Property="Foreground" Value="{StaticResource GreenDark}"/></Trigger></Style.Triggers></Style></Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="7"/>
                            <ToggleButton x:Name="DropDownToggle" Background="Transparent" BorderThickness="0" Focusable="False" IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}" ClickMode="Press">
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="30"/></Grid.ColumnDefinitions><ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/><Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0" Stroke="{StaticResource GreenDark}" StrokeThickness="1.6" HorizontalAlignment="Center" VerticalAlignment="Center"/></Grid>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup" IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" AllowsTransparency="True" Focusable="False" PopupAnimation="Fade"><Border Margin="0,4,0,0" MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}" MaxHeight="300" Background="White" BorderBrush="{StaticResource Green}" BorderThickness="1" CornerRadius="7"><ScrollViewer VerticalScrollBarVisibility="Auto"><ItemsPresenter/></ScrollViewer></Border></Popup>
                        </Grid>
                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ComboBorder" Property="BorderBrush" Value="#87B89A"/></Trigger><Trigger Property="IsKeyboardFocusWithin" Value="True"><Setter TargetName="ComboBorder" Property="BorderBrush" Value="{StaticResource Green}"/></Trigger><Trigger Property="IsEnabled" Value="False"><Setter TargetName="ComboBorder" Property="Background" Value="#F1F4F2"/><Setter Property="Opacity" Value="0.6"/></Trigger></ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,4"/><Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{StaticResource Ink}"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="18"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Border x:Name="CheckBorder" Width="16" Height="16" Background="White" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="4" VerticalAlignment="Center">
                                <Path x:Name="CheckMark" Data="M 3 7 L 6 10 L 12 4" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Grid.Column="1" Margin="6,0,0,0" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="CheckBorder" Property="BorderBrush" Value="{StaticResource Green}"/></Trigger>
                            <Trigger Property="IsChecked" Value="True"><Setter TargetName="CheckBorder" Property="Background" Value="{StaticResource Green}"/><Setter TargetName="CheckBorder" Property="BorderBrush" Value="{StaticResource Green}"/><Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/></Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True"><Setter TargetName="CheckBorder" Property="BorderBrush" Value="{StaticResource GreenDark}"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.5"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GreenProgress" TargetType="ProgressBar">
            <Setter Property="Height" Value="7"/><Setter Property="Background" Value="#DCE5DE"/><Setter Property="Foreground" Value="{StaticResource Green}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="PART_Track" ClipToBounds="True">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4"/>
                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left" Background="{TemplateBinding Foreground}" CornerRadius="4"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FileColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="#E9F4ED"/>
            <Setter Property="Foreground" Value="{StaticResource GreenDark}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#D2E5D8"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
        <Style x:Key="CenteredColumnHeader" TargetType="DataGridColumnHeader" BasedOn="{StaticResource FileColumnHeader}">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource GreenSelection}"/>
                    <Setter Property="Foreground" Value="#123D27"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E9EFEB"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1"><Setter Property="Background" Value="#F7FAF8"/></Trigger>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#EDF7F1"/></Trigger>
                <Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="{StaticResource GreenSelection}"/></Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CenteredCellText" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="Padding" Value="13,8"/>
            <Setter Property="MinWidth" Value="165"/>
            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
            <Style.Triggers><Trigger Property="IsHighlighted" Value="True"><Setter Property="Background" Value="{StaticResource GreenSoft}"/></Trigger></Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="18,13,18,15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="150"/>
            <RowDefinition Height="6"/>
            <RowDefinition x:Name="BottomRow" Height="176" MinHeight="160"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="2,0,2,10">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Image Source="Assets/AppIcon.png" Width="34" Height="34" Margin="0,0,10,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="内网文件传输工具" Foreground="{StaticResource Ink}" FontSize="23" FontWeight="SemiBold"/>
                    <TextBlock Text="局域网文件收发" Foreground="{StaticResource Muted}" FontSize="11" Margin="1,1,0,0"/>
                </StackPanel>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal"><Button Content="关于" Padding="10,5" MinHeight="30" Click="AboutButton_Click"/><Border Background="{StaticResource GreenSoft}" CornerRadius="14" Padding="11,6" VerticalAlignment="Center"><StackPanel Orientation="Horizontal"><Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#A4AAA6" Margin="0,0,7,0"/><TextBlock x:Name="StatusText" Text="正在启动…" Foreground="{StaticResource Green}" FontWeight="SemiBold"/></StackPanel></Border></StackPanel>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,10" Padding="15,12">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="180"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="84"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="访问地址" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,9,0"/>
                <ComboBox x:Name="IpAddressCombo" Grid.Column="1" SelectionChanged="IpAddressCombo_SelectionChanged" ToolTip="{Binding SelectedItem, RelativeSource={RelativeSource Self}}"/>
                <TextBlock Grid.Column="2" Text="端口" FontWeight="SemiBold" VerticalAlignment="Center" Margin="15,0,7,0"/>
                <TextBox x:Name="PortTextBox" Grid.Column="3" Text="28080"/>
                <TextBox x:Name="AddressTextBox" Grid.Column="4" Margin="13,0,0,0" IsReadOnly="True" Background="#F6F8F6"/>
                <WrapPanel Grid.Row="1" Grid.ColumnSpan="5" Margin="0,10,0,0">
                    <Button x:Name="StartButton" Content="启动服务" Style="{StaticResource PrimaryButton}" Click="StartButton_Click"/>
                    <Button x:Name="StopButton" Content="停止服务" Style="{StaticResource DangerButton}" Click="StopButton_Click"/>
                    <Button Content="打开 Web 页面" Click="OpenWebButton_Click"/>
                    <Button Content="显示二维码" Click="QrButton_Click"/>
                    <ComboBox x:Name="BindingModeCombo" Width="130" SelectionChanged="BindingModeCombo_SelectionChanged"/>
                    <Button Content="刷新网卡" Click="RefreshNetworkButton_Click"/>
                    <TextBlock x:Name="LanWarningText" Margin="5,8,0,0" Foreground="{StaticResource Muted}" Text="局域网免登录，请勿分享敏感文件"/>
                </WrapPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="50"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <Grid Margin="16,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="共享文件" FontSize="18" FontWeight="SemiBold"/>
                        <TextBlock x:Name="FileCountText" Text="0 个文件" Foreground="{StaticResource Muted}" Margin="10,3,0,0"/>
                        <TextBlock x:Name="ContextHintText" Text="· 右键文件可进行更多操作" Foreground="#829087" Margin="8,3,0,0"/>
                    </StackPanel>
                    <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                        <Grid Width="160" Margin="0,0,7,0">
                            <TextBox x:Name="FileSearchTextBox" ToolTip="按文件名搜索" TextChanged="FileSearchTextBox_TextChanged"/>
                            <TextBlock Text="搜索文件" Foreground="#8A958E" Margin="10,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers><DataTrigger Binding="{Binding Text, ElementName=FileSearchTextBox}" Value=""><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        <Button Content="添加文件" Style="{StaticResource PrimaryButton}" Click="AddFilesButton_Click"/>
                        <Button x:Name="CancelImportButton" Content="取消添加" IsEnabled="False" Click="CancelImportButton_Click"/>
                        <Button Content="打开目录" Margin="0" Click="OpenDirectoryButton_Click"/>
                    </WrapPanel>
                </Grid>
                <Border x:Name="ImportProgressPanel" Grid.Row="1" Margin="16,0,16,9" Padding="12,9" Background="#F3F8F4" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="9" Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock x:Name="ImportProgressNameText" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="ImportProgressDetailsText" Grid.Column="1" Margin="12,0,0,0" Foreground="{StaticResource Muted}"/>
                        <ProgressBar x:Name="ImportProgressBar" Grid.Row="1" Grid.ColumnSpan="2" Margin="0,7,0,0" Minimum="0" Maximum="100" Style="{StaticResource GreenProgress}"/>
                    </Grid>
                </Border>
                <DataGrid x:Name="FilesGrid" Grid.Row="2" ItemsSource="{Binding Files}" AutoGenerateColumns="False"
                          SelectionMode="Extended" SelectionUnit="FullRow" IsReadOnly="True" BorderThickness="0"
                          CanUserResizeColumns="True" CanUserSortColumns="True" HeadersVisibility="Column"
                          EnableRowVirtualization="True" EnableColumnVirtualization="True" GridLinesVisibility="None"
                          AlternationCount="2" ColumnHeaderStyle="{StaticResource FileColumnHeader}"
                          PreviewMouseRightButtonDown="FilesGrid_PreviewMouseRightButtonDown"
                          ContextMenuOpening="FileContextMenu_Opening">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="复制文件链接" Click="ContextCopyFileLink_Click"/>
                            <MenuItem Header="打开文件二维码" Click="ContextFileQr_Click"/>
                            <Separator/>
                            <MenuItem Header="编辑文件" Click="ContextEditFile_Click"/>
                            <MenuItem Header="删除文件" Foreground="#A92F2F" Click="ContextDeleteFile_Click"/>
                            <Separator/>
                            <MenuItem Header="打开文件目录" Click="ContextOpenDirectory_Click"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="52" IsReadOnly="True" CanUserSort="False" HeaderStyle="{StaticResource CenteredColumnHeader}" ElementStyle="{StaticResource CenteredCellText}"/>
                        <DataGridTemplateColumn Header="文件名" Width="*" MinWidth="220">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Name}" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="大小" Binding="{Binding DisplaySize}" Width="120" HeaderStyle="{StaticResource CenteredColumnHeader}" ElementStyle="{StaticResource CenteredCellText}"/>
                        <DataGridTextColumn Header="修改时间" Binding="{Binding DisplayModified}" Width="180" SortDirection="Descending" HeaderStyle="{StaticResource CenteredColumnHeader}" ElementStyle="{StaticResource CenteredCellText}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <GridSplitter Grid.Row="3" Height="6" HorizontalAlignment="Stretch" VerticalAlignment="Center" Background="Transparent" ResizeDirection="Rows" ResizeBehavior="PreviousAndNext" Cursor="SizeNS"/>

        <Grid x:Name="BottomPanel" Grid.Row="4">
            <Grid.ColumnDefinitions><ColumnDefinition x:Name="SettingsColumn" Width="0.95*" MinWidth="330"/><ColumnDefinition Width="10"/><ColumnDefinition x:Name="LogColumn" Width="1.25*" MinWidth="360"/></Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="14,11">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <TextBlock Text="基础设置" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Text="共享目录" VerticalAlignment="Center"/><TextBox x:Name="UploadDirectoryTextBox" Grid.Column="1"/>
                        <Button Grid.Column="2" Content="选择" Margin="7,0,0,0" Click="BrowseDirectoryButton_Click"/>
                    </Grid>
                    <Grid Grid.Row="2" Margin="0,7,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="115"/><ColumnDefinition Width="80"/><ColumnDefinition Width="90"/></Grid.ColumnDefinitions>
                        <TextBlock Text="同名处理" VerticalAlignment="Center"/><ComboBox x:Name="DuplicateBehaviorCombo" Grid.Column="1"/>
                        <TextBlock Grid.Column="2" Text="上限(GB)" Margin="12,0,6,0" VerticalAlignment="Center"/><TextBox x:Name="MaxUploadGbTextBox" Grid.Column="3"/>
                    </Grid>
                    <Grid Grid.Row="3" Margin="0,6,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <WrapPanel VerticalAlignment="Top">
                            <CheckBox x:Name="LanOnlyCheckBox" Content="仅局域网" Margin="0,4,14,4"/>
                            <CheckBox x:Name="AllowWebUploadCheckBox" Content="Web 上传" Margin="0,4,14,4"/>
                            <CheckBox x:Name="AllowWebDeleteCheckBox" Content="Web 删除" Margin="0,4,0,4"/>
                            <CheckBox x:Name="ReadOnlyModeCheckBox" Content="只读模式" Margin="14,4,0,4"/>
                        </WrapPanel>
                        <Button Grid.Column="1" Content="保存设置" Style="{StaticResource PrimaryButton}" Margin="8,3,0,0" VerticalAlignment="Top" Click="SaveSettingsButton_Click"/>
                    </Grid>
                </Grid>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="40"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <Grid Margin="14,0"><TextBlock Text="运行日志" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/><WrapPanel HorizontalAlignment="Right" VerticalAlignment="Center"><Button Content="复制" Padding="10,5" MinHeight="30" Click="CopyLogsButton_Click"/><Button Content="清空显示" Padding="10,5" MinHeight="30" Click="ClearLogDisplayButton_Click"/><Button Content="打开日志目录" Margin="0" Padding="10,5" MinHeight="30" Click="OpenLogsButton_Click"/></WrapPanel></Grid>
                    <TextBox x:Name="LogTextBox" Grid.Row="1" Margin="10,0,10,10" IsReadOnly="True" TextWrapping="NoWrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" FontFamily="Consolas, Microsoft YaHei UI" FontSize="11.5" Background="#F8FAF8"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
